{
  "name": "Collection Miner",
  "description": "Randomly surface bookmarks on each new tab.",
  "version": "0.1.0",
  "manifest_version": 3,
  "permissions": ["bookmarks", "storage"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  }
}
