{
  "name": "Collection Miner",
  "description": "Rediscover forgotten bookmarks and Douban records on every new tab, with weighted card ratings.",
  "version": "0.3.9",
  "manifest_version": 3,
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["bookmarks", "storage", "tabs"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  }
}
